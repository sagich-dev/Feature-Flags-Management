{
	"name": "@feature-flags/backend",
	"version": "1.0.0",
	"private": true,
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"engines": {
		"node": ">=20.6.0",
		"pnpm": ">=10.0.0"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/index.mjs",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsdown --env.APP_VERSION=$npm_package_version",
		"start:dev": "tsx watch src/index.ts",
		"start:prod": "cross-env NODE_ENV=production node --env-file=.env --enable-source-maps --max-old-space-size=512 dist/index.mjs",
		"lint": "biome check",
		"format": "biome check --write",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage"
	},
	"dependencies": {
		"@scalar/api-reference": "^1.28.0",
		"compression": "^1.8.1",
		"cors": "^2.8.5",
		"express": "5.2.1",
		"express-rate-limit": "8.0.1",
		"helmet": "8.1.0",
		"http-status-codes": "2.3.0",
		"openapi-types": "^12.1.3",
		"pino": "^10.1.1",
		"pino-http": "10.5.0",
		"tsconfig-paths": "^4.2.0",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@types/compression": "^1.8.1",
		"@types/cors": "2.8.19",
		"@types/express": "5.0.3",
		"@types/express-serve-static-core": "^5.1.0",
		"@types/node": "^25.0.3",
		"@types/supertest": "6.0.3",
		"@vitest/coverage-v8": "4.0.16",
		"cross-env": "^10.1.0",
		"pino-pretty": "13.1.1",
		"supertest": "7.1.4",
		"tsdown": "^0.20.0-beta.1",
		"tsx": "4.21.0",
		"typescript": "5.9.2",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "4.0.16"
	},
	"tsdown": {
		"entry": [
			"src/index.ts"
		],
		"outDir": "dist",
		"format": [
			"esm",
			"cjs"
		],
		"target": "es2020",
		"sourcemap": true,
		"clean": true,
		"dts": true,
		"splitting": false,
		"skipNodeModulesBundle": true
	}
}
